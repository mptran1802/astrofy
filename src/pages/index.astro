---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5 max-w-3xl">
    <!-- Intro Block -->
    <div class="text-xl py-1">Hey there!</div>
    <div class="text-5xl font-bold">I'm Minh Anh Tran</div>
    <div class="text-3xl py-3 font-bold text-primary">Brain | Tech | Art</div>
    
    <div class="py-2 text-base text-justify leading-relaxed">
      A neuroscientist and developer in the making, I blend wet-lab research, coding, and contemporary poetry to explore the mind and transform science into stories that connect.
    </div>

    <!-- Clean, Aesthetic Demographics Bullet Points -->
    <div class="mt-8 mb-8 space-y-4 border-l-2 border-primary/30 pl-5">
      <div class="flex items-center gap-3 group">
        <div class="bg-base-200 p-2.5 rounded-xl text-lg group-hover:bg-primary/10 transition-colors">
          🎓
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-base-content/50 font-semibold">Education</span>
          <span class="text-base font-medium text-base-content/90">University of Southern California</span>
        </div>
      </div>
      
      <div class="flex items-center gap-3 group">
        <div class="bg-base-200 p-2.5 rounded-xl text-lg group-hover:bg-primary/10 transition-colors">
          🧬
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-base-content/50 font-semibold">Major</span>
          <span class="text-base font-medium text-base-content/90">Neuroscience</span>
        </div>
      </div>

      <div class="flex items-center gap-3 group">
        <div class="bg-base-200 p-2.5 rounded-xl text-lg group-hover:bg-primary/10 transition-colors">
          📅
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-base-content/50 font-semibold">Expected Graduation</span>
          <span class="text-base font-medium text-base-content/90">May 2029</span>
        </div>
      </div>

      <div class="flex items-center gap-3 group">
        <div class="bg-base-200 p-2.5 rounded-xl text-lg group-hover:bg-primary/10 transition-colors">
          📍
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-base-content/50 font-semibold">Location</span>
          <span class="text-base font-medium text-base-content/90">Los Angeles, CA</span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="mt-8">
      <!-- Primary Resume Button pointing directly to your PDF -->
      <a 
        href="/resume.pdf" 
        target="_blank" 
        class="btn btn-primary inline-flex items-center gap-2 normal-case shadow-md transition-all hover:scale-[1.02]"
      >
        <span>View Resume</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
</BaseLayout>
